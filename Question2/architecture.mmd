flowchart LR
    subgraph Channels
        Chat[Web / Mobile Chat]
        Voice[SIP / Telephony]
    end

    subgraph Voice_Path[Voice Runtime Path]
        SBC[Session Border Controller / SIP Provider]
        Turn[Turn Detection / Barge-In Control]
        STT[Streaming STT]
        TTS[Text to Speech]
    end

    subgraph Serving[Shared Orchestration Core]
        API[Channel API / Orchestrator]
    end

    subgraph State[State and Knowledge]
        Memory[(Redis Session Memory)]
        Alias[Versioned Serving Alias]
        Qdrant[(Qdrant)]
        LLM[LLM Gateway / Model Provider]
        SQL[(Postgres)]
    end

    subgraph Handoff[Handoff and Monitoring]
        Escalation[Human Escalation Service]
        Agents[Agent Desktop / CRM]
        Obs[Langfuse + OpenTelemetry + Metrics]
    end

    subgraph Offline[Offline Update and Evaluation Loop]
        Store[(Object Storage / Admin Uploads)]
        Ingestion[Document Ingestion Pipeline]
        Embed[Embedding Worker]
        Eval[Offline Eval Runner]
    end

    Chat --> API
    Voice --> SBC --> Turn --> STT --> API
    API --> TTS --> SBC

    API <--> Memory
    API --> Alias --> Qdrant
    API --> LLM
    API --> SQL

    API --> Escalation --> Agents
    API --> Obs
    LLM --> Obs
    Qdrant --> Obs
    SQL --> Obs

    Store -.-> Ingestion --> Embed --> Qdrant
    Ingestion -. validate and promote .-> Alias
    SQL -. evaluation datasets .-> Eval --> Obs
